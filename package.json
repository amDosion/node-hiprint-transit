{
  "name": "node-hiprint-transit",
  "version": "1.0.1",
  "description": "A nodejs server for hiprint transit",
  "main": "index.js",
  "type": "module",
  "scripts": {
    "init": "node ./init.js",
    "serve": "node ./index.js",
    "test": "node --test",
    "audit": "npm audit",
    "check:docker": "node ./scripts/docker-smoke.js",
    "check:workflow": "bash ./scripts/codex/validate-workflow.sh",
    "check:prettier": "prettier --check \"**/*.{js,json,md,yml,yaml}\"",
    "check:syntax": "node --check index.js && node --check init.js && node --check start.js && node --check src/config.js && node --check src/init-config.js && node --check src/log.js && node --check src/protocol.js && node --check scripts/fetchNode.js && node --check scripts/createExe.js && node --check scripts/docker-smoke.js",
    "check:bundle": "node --check dist/index.js && node --check out/index.js",
    "verify": "npm run audit && npm test && npm run check:workflow && npm run check:prettier && npm run build && npm run check:syntax && npm run check:bundle",
    "build": "rollup -c && node ./scripts/fetchNode.js",
    "lint:prettier": "prettier --write \"**/*.{js,json,md,yml,yaml}\"",
    "package": "node ./scripts/createExe.js"
  },
  "repository": {
    "type": "git",
    "url": "http://192.168.50.97/root/node-hiprint-transit.git"
  },
  "keywords": [
    "hiprint",
    "transit",
    "node"
  ],
  "author": "xavier",
  "license": "MIT",
  "bugs": {
    "url": "http://192.168.50.97/root/node-hiprint-transit/-/issues"
  },
  "homepage": "http://192.168.50.97/root/node-hiprint-transit#readme",
  "dependencies": {
    "chalk": "^5.6.2",
    "cli-progress": "^3.12.0",
    "dayjs": "^1.11.21",
    "i18n": "^0.15.3",
    "inquirer": "^14.0.2",
    "node-forge": "^1.4.0",
    "punycode": "^2.3.1",
    "socket.io": "^4.8.3"
  },
  "devDependencies": {
    "@rollup/plugin-commonjs": "^29.0.3",
    "@rollup/plugin-json": "^6.1.0",
    "@rollup/plugin-node-resolve": "^16.0.3",
    "prettier": "^3.8.3",
    "rollup": "^4.61.1",
    "rollup-plugin-delete": "^3.0.2"
  },
  "engines": {
    "node": ">=24"
  }
}
